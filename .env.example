# ─── Mode ────────────────────────────────────────────────────────────────────
# Set PAPER_TRADE=false to go live. All other config is shared.
PAPER_TRADE=true

# ─── Polymarket ──────────────────────────────────────────────────────────────
# Your EOA wallet private key on Polygon (0x-prefixed).
# First run: set only POLY_PRIVATE_KEY; the bot will derive API creds
# and print them. Then fill in the three fields below.
POLY_PRIVATE_KEY=0x_your_polygon_wallet_private_key
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=
POLY_CHAIN_ID=137

# ─── Kalshi ──────────────────────────────────────────────────────────────────
# Create an API key at kalshi.com → Settings → API. Download the PEM file.
# For paper/demo trading use demo-api.kalshi.co (set automatically when PAPER_TRADE=true).
KALSHI_API_KEY_ID=your-kalshi-api-key-uuid
KALSHI_PRIVATE_KEY_PATH=./secrets/kalshi_private.pem

# ─── LLM ─────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key

# ─── News & Research ─────────────────────────────────────────────────────────
# Tavily: https://tavily.com (purpose-built for LLM agents, ~$20/mo for 2k searches)
# Replaces NewsAPI — better quality, no daily caps, AI-synthesized summaries
TAVILY_API_KEY=tvly-your-key

# Exa.ai: https://exa.ai (semantic search, free tier: 1k/mo)
EXA_API_KEY=your-exa-api-key

# Metaculus: https://www.metaculus.com/accounts/profile/ → API (free)
# Required — their API now blocks unauthenticated requests.
METACULUS_API_KEY=your-metaculus-api-key

# ─── Capital ─────────────────────────────────────────────────────────────────
# Total USD allocated to each platform. Used as bankroll denominator for Kelly.
BANKROLL_POLY_USD=5000.0
BANKROLL_KALSHI_USD=5000.0

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
